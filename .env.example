# ------------------------------------------------------------------------------
# Automation Engine Environment Configuration
# ------------------------------------------------------------------------------

# General Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=your-email@gmail.com

# Notification Channels
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_WEBHOOK_TOKEN
SLACK_API_TOKEN=xoxb-your-slack-bot-token
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# External API Configuration
EXTERNAL_API_URL=https://api.placeholder-service.com/v1
EXTERNAL_API_KEY=your_secret_api_key_here

# Paths (can be relative to repository root or absolute)
DATA_INPUT_DIR=data/input
DATA_OUTPUT_DIR=data/output
LOGS_DIR=logs
